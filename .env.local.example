# Resend API key — hent fra https://resend.com/api-keys
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Admin-panel passord — velg selv
ADMIN_PASSWORD=ditt-hemmelige-passord

# Vercel KV (for admin-panel) — sett opp via Vercel Dashboard → Storage → KV
# https://vercel.com/docs/storage/vercel-kv/quickstart
KV_REST_API_URL=https://xxxxxx.upstash.io
KV_REST_API_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxx

# Hostaway API — hent fra https://dashboard.hostaway.com/ → Settings → API
# Brukes for å hente reviews fra Airbnb/Booking.com og vise tilgjengelighet
HOSTAWAY_CLIENT_ID=your_client_id
HOSTAWAY_CLIENT_SECRET=your_client_secret
